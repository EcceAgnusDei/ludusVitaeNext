DATABASE_URL=postgresql://user:password@localhost:5432/ludus_vitae

# Obligatoire — ex. openssl rand -base64 32
BETTER_AUTH_SECRET=

# URL publique de l’app (sans slash final). Utilisée par le client auth et par défaut côté serveur.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optionnel — si défini, remplace NEXT_PUBLIC_APP_URL pour Better Auth uniquement (ex. URL interne vs publique).
# BETTER_AUTH_URL=http://localhost:3000

# Optionnel — origines supplémentaires (séparées par des virgules), ex. previews Vercel.
# BETTER_AUTH_TRUSTED_ORIGINS=https://branch-xxx.vercel.app

# Resend (transactional email)
RESEND_API_KEY=
