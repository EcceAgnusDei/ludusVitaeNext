DATABASE_URL=postgresql://user:password@localhost:5432/ludus_vitae

# Better Auth — generate e.g. openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of this app (same value is fine for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (transactional email)
RESEND_API_KEY=
# Tests d’intégration HTTP (`pnpm test`) — serveur Next requis sur cette origine
# TEST_API_BASE_URL=http://127.0.0.1:3000
# Cookie de session utilisateur A (Better Auth), format en-tête brut : `nom=valeur` (devtools)
# GRIDS_TEST_AUTH_COOKIE=
# Deuxième compte B, distinct de A — requis pour les tests « tiers » (profil, PATCH/DELETE, like)
# GRIDS_TEST_AUTH_COOKIE_B=
# UUID d’une grille appartenant à l’utilisateur de la session (pour F8 / G5 idempotents)
# GRIDS_TEST_GRID_ID=

